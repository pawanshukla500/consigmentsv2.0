# ═══════════════════════════════════════════════════════════
# Consignment Packing App — Environment Variables
# Copy this file to .env and fill in your real values.
# This single .env serves BOTH frontend and backend.
# ═══════════════════════════════════════════════════════════

# ─── Backend ───
PORT=5000
NODE_ENV=development
JWT_SECRET=change-this-to-a-strong-random-string-in-production

# Firebase (Backend Admin SDK)
FIREBASE_PROJECT_ID=consignment-packing-app
FIREBASE_STORAGE_BUCKET=consignment-packing-app.firebasestorage.app
# GOOGLE_APPLICATION_CREDENTIALS=./backend/serviceAccountKey.json

# CORS (production)
# ALLOWED_ORIGINS=https://your-app.web.app,https://your-app.firebaseapp.com

# ─── Frontend (Vite requires VITE_ prefix) ───
VITE_API_URL=http://localhost:5000

# Firebase Web SDK Config (from Firebase Console > Project Settings > Web App)
VITE_FIREBASE_API_KEY=AIzaSyAgrDquv5-Rw6JAxFpzGnnGxCHfMhpMHdg
VITE_FIREBASE_AUTH_DOMAIN=consignment-packing-app.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=consignment-packing-app
VITE_FIREBASE_STORAGE_BUCKET=consignment-packing-app.firebasestorage.app
