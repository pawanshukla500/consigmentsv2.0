# Copy this file to .env and fill in your values

PORT=5000
NODE_ENV=production
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Firebase Admin Configuration
# Get these from Firebase Console > Project Settings > General
FIREBASE_PROJECT_ID=consignment-packing-app
FIREBASE_STORAGE_BUCKET=consignment-packing-app.firebasestorage.app

# For local development: path to your serviceAccountKey.json
# For cloud deployment: set GOOGLE_APPLICATION_CREDENTIALS env var or use default credentials
# GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json

# Optional: Firestore Emulator for local development
# FIRESTORE_EMULATOR_HOST=localhost:8080

# PostgreSQL Configuration (Cloud SQL / Aiven / External DB)
DB_USE_POSTGRES=true
DATABASE_URL=postgres://user:password@host:port/dbname?sslmode=require
# Or specify individual credentials:
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=postgres
# DB_USER=postgres
# DB_PASSWORD=
# DB_SSL=true
# INSTANCE_CONNECTION_NAME=project:region:instance
